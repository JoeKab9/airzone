# Airzone HVAC Control — Environment Variables
# Copy this file to .env and fill in your credentials.
# .env is gitignored and stays local to this project.

# ── Airzone Cloud ──────────────────────────────────────────────
AIRZONE_EMAIL=
AIRZONE_PASSWORD=

# ── Netatmo API ────────────────────────────────────────────────
NETATMO_CLIENT_ID=
NETATMO_CLIENT_SECRET=

# ── Linky / Enedis ─────────────────────────────────────────────
LINKY_TOKEN=
LINKY_PRM=

# ── Runtime tokens (managed automatically — do not edit) ──────
# AIRZONE_TOKEN=
# AIRZONE_REFRESH_TOKEN=
# AIRZONE_TOKEN_EXPIRY=
# NETATMO_ACCESS_TOKEN=
# NETATMO_REFRESH_TOKEN=
# NETATMO_TOKEN_OBTAINED=
# NETATMO_TOKEN_EXPIRES_IN=
