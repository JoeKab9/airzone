[Unit]
Description=Airzone Web Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/airzone/pi
ExecStart=/home/pi/airzone/venv/bin/gunicorn -w 1 -b 0.0.0.0:5000 airzone_dashboard:app
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
